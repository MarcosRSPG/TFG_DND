{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach FastAPI Docker (5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/API",
          "remoteRoot": "/app"
        }
      ],
      "justMyCode": false,
      "subProcess": true
    }
  ]
}