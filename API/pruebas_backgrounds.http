### Variables base
@host = http://localhost:8000
@api_token_hash = 32e469f398b2dd6e89892d33012ae447e046070c18c9f6c5f1a2430a039e5db7

### Login previo
# @name login
POST {{host}}/auth/login
Content-Type: application/json
X-API-Token: {{api_token_hash}}

{
  "username": "Oraxiel",
  "password": "admin"
}

### Listar backgrounds
GET {{host}}/backgrounds
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

### Obtener background por id
GET {{host}}/backgrounds/66c8f1c2b1a2c3d4e5f67890
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

### Crear background
POST {{host}}/backgrounds
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "index": "criminal-wikidot",
  "name": "Criminal",
  "starting_proficiencies": [
    {
      "index": "skill-deception",
      "name": "Skill: Deception",
      "url": "https://www.dnd5eapi.co/api/2014/proficiencies/skill-deception"
    },
    {
      "index": "skill-stealth",
      "name": "Skill: Stealth",
      "url": "https://www.dnd5eapi.co/api/2014/proficiencies/skill-stealth"
    }
  ],
  "feature": {
    "name": "Contacto criminal",
    "desc": [
      "Mantienes una red de contactos en los bajos fondos.",
      "Sabes a quien preguntar cuando necesitas algo discreto."
    ]
  },
  "source": "wikidot.dnd5e"
}

### Actualizar background
PUT {{host}}/backgrounds/66c8f1c2b1a2c3d4e5f67890
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "index": "criminal-wikidot",
  "name": "Criminal Updated",
  "starting_proficiencies": [
    {
      "index": "skill-deception",
      "name": "Skill: Deception",
      "url": "https://www.dnd5eapi.co/api/2014/proficiencies/skill-deception"
    }
  ],
  "feature": {
    "name": "Contacto criminal",
    "desc": [
      "Tu red de contactos es aun mas util que antes."
    ]
  },
  "source": "wikidot.dnd5e"
}

### Eliminar background
DELETE {{host}}/backgrounds/66c8f1c2b1a2c3d4e5f67890
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}
