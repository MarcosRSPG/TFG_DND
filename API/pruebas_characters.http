### Variables base
@host = http://localhost:8000
@api_token_hash = 32e469f398b2dd6e89892d33012ae447e046070c18c9f6c5f1a2430a039e5db7

### Login previo
# @name login
POST {{host}}/auth/login
Content-Type: application/json
X-API-Token: {{api_token_hash}}

{
  "username": "Oraxiel",
  "password": "admin"
}

### GET ALL CHARACTERS (solo X-API-Token)
GET {{host}}/characters
Content-Type: application/json
X-API-Token: {{api_token_hash}}

### GET SPECIFIC CHARACTER (solo X-API-Token)
GET {{host}}/characters/Liora
Content-Type: application/json
X-API-Token: {{api_token_hash}}

### CREATE NEW CHARACTER (requiere X-API-Token + Authorization)
POST {{host}}/characters
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "name": "Test Character",
  "level": 1,
  "class": {
    "index": "wizard",
    "url": "https://www.dnd5eapi.co/api/2014/classes/wizard"
  },
  "race": {
    "index": "human",
    "url": "https://www.dnd5eapi.co/api/2014/races/human"
  },
  "background": {
    "index": "acolyte",
    "url": "https://www.dnd5eapi.co/api/2014/backgrounds/acolyte"
  },
  "alignment": "neutral",
  "hit_points": 8,
  "hit_dice": "1d6",
  "hit_points_roll": "1d6",
  "speed": {
    "walk": "30 ft."
  },
  "strength": 8,
  "dexterity": 14,
  "constitution": 12,
  "intelligence": 16,
  "wisdom": 10,
  "charisma": 10,
  "proficiencies": [],
  "proficiency_bonus": 2,
  "saving_throws": ["int", "wis"],
  "inventory": {
    "items": ["battleaxe", "shield"],
    "cash": {"cp": 0, "sp": 10, "gp": 5, "pp": 0}
  },
  "spellcasting": {
    "spell_slots": {"1": 2},
    "known_spells": ["magic-missile"],
    "prepared_spells": ["magic-missile"],
    "spell_save_dc": 13,
    "spell_attack_bonus": 5
  },
  "campaings": ["SombraDragon2026_id"],
  "tags": ["pj", "wizard"],
  "notes": "Character test created from HTTP file",
  "_meta": {
    "is_deleted": false,
    "image_url": "/api/images/characters/test-character.png",
    "token_url": "/api/tokens/characters/test-character-token.png"
  }
}

### UPDATE CHARACTER (requiere X-API-Token + Authorization)
PUT {{host}}/characters/test-character
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

{
  "name": "Test Character Updated",
  "level": 2,
  "class": {
    "index": "wizard",
    "url": "https://www.dnd5eapi.co/api/2014/classes/wizard"
  },
  "race": {
    "index": "human",
    "url": "https://www.dnd5eapi.co/api/2014/races/human"
  },
  "background": {
    "index": "acolyte",
    "url": "https://www.dnd5eapi.co/api/2014/backgrounds/acolyte"
  },
  "alignment": "neutral",
  "hit_points": 10,
  "hit_dice": "2d6",
  "hit_points_roll": "2d6",
  "speed": {
    "walk": "30 ft."
  },
  "strength": 8,
  "dexterity": 14,
  "constitution": 12,
  "intelligence": 17,
  "wisdom": 10,
  "charisma": 10,
  "proficiencies": [],
  "proficiency_bonus": 2,
  "saving_throws": ["int", "wis"],
  "inventory": {
    "items": ["battleaxe"],
