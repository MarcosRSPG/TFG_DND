    "token_url": "/api/tokens/characters/test-character-updated-token.png"
  }
}

### GET UPDATED CHARACTER (solo X-API-Token)
GET {{host}}/characters/test-character
Content-Type: application/json
X-API-Token: {{api_token_hash}}

### DELETE CHARACTER (requiere X-API-Token + Authorization)
DELETE {{host}}/characters/test-character
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}

### VERIFY CHARACTER DELETED (should return 404)
GET {{host}}/characters/test-character
Content-Type: application/json
X-API-Token: {{api_token_hash}}

### CREATE CHARACTER WITH INVALID CLASS (should return 422)
