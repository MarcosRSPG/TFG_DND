  "xp": 1100,
  "url": "/api/2014/monsters/test-monster"
}


### GET UPDATED MONSTER (solo X-API-Token)
GET {{host}}/monsters/test-monster
Content-Type: application/json
X-API-Token: {{api_token_hash}}


### DELETE MONSTER (requiere X-API-Token + Authorization)
DELETE {{host}}/monsters/test-monster
Content-Type: application/json
X-API-Token: {{api_token_hash}}
Authorization: Bearer {{login.response.body.$.access_token}}


### VERIFY MONSTER DELETED (should return 404)
GET {{host}}/monsters/test-monster
Content-Type: application/json
X-API-Token: {{api_token_hash}}
